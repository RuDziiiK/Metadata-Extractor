<Window x:Class="GuiApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GuiApp.Views"
        Title="Metadata Viewer" Height="450" Width="800">
    <Window.Icon>
        <BitmapImage UriSource="C:\Users\Fillo\source\repos\MetaData\Assets\metadataIcon.ico" />
    </Window.Icon>
    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Pluginy">
                <MenuItem Header="Plugin DLL" Click="Plugin_DLL_Click"/>
                <MenuItem Header="Plugin XML" Click="Plugin_XML_Click"/>
                <MenuItem Header="Plugin DB" Click="Plugin_DB_Click"/>
            </MenuItem>
            <MenuItem Header="Zapisz">
                <MenuItem Header="Do XML" Click="Save_XML_Click"/>
                <MenuItem Header="Do bazy danych" Click="Save_DB_Click"/>
            </MenuItem>
        </Menu>

        <!-- Kontrolki na dole -->
        <Grid DockPanel.Dock="Top">
            <TextBlock x:Name="PluginInfoText" Text="Wybierz plugin" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0" FontSize="30" Foreground="Black" FontWeight="Bold"/>
            <Button x:Name="LoadMetadataButton" Content="Załaduj plik" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,70,0,0" Click="LoadMetadataButton_Click"/>
        </Grid>

        <!-- TreeView na główną część okna -->
        <TreeView x:Name="TreeView" Margin="20,10,20,20" FontSize="14"/>
    </DockPanel>
</Window>
